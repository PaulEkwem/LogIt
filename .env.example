# Copy to .env.local and fill in from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-side only — used by admin operations (creating AM auth users, etc.)
# NEVER expose this on the client. Keep it out of git; paste straight into Vercel env vars.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
